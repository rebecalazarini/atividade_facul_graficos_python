# Importação das bibliotecas
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import plotly.express as px

import pandas as pd
# Carregar CSV usando latin1
df = pd.read_csv(
    'consumo-de-energia-eletrica-no-palacio-do-jaburu-2017-2024-setembro.csv',
    encoding='latin1',
    sep=';'
)

# Mostrar dados
df.head()

# Remover espaços extras dos nomes das colunas
df.columns = df.columns.str.strip()

# Limpar coluna de valores

df['VALOR BRUTO DA FATURA'] = (
    df['VALOR BRUTO DA FATURA']
    .str.replace('R$', '', regex=False)
    .str.replace('.', '', regex=False)
    .str.replace(',', '.', regex=False)
)

# Converter para float
df['VALOR BRUTO DA FATURA'] = df['VALOR BRUTO DA FATURA'].astype(float)

print(df.head())

# Tedências anuais

import matplotlib.pyplot as plt

#Agrupar dados
consumo_anual = df.groupby('ANO')['CONSUMO-KWH'].sum()
fatura_anual = df.groupby('ANO')['VALOR BRUTO DA FATURA'].mean()

#Grafico
plt.figure(figsize=(10,5))

plt.plot(
    consumo_anual.index,
    consumo_anual.values,
    marker='o',
    label='consumo total'
)

plt.plot(
    fatura_anual.index,
    fatura_anual.values,
    marker='o',
    label='valor medio da fatura'
)

plt.title('Tendencias anuais')
plt.xlabel('Ano')
plt.ylabel('Valores')
plt.legend()
plt.show()

import seaborn as sns

# Consumo médio por mês
consumo_mensal = df.groupby('MÊS')['CONSUMO-KWH'].mean().reset_index()

# Gráfico
plt.figure(figsize=(12,5))

sns.barplot(
    x='MÊS',
    y='CONSUMO-KWH',
    data=consumo_mensal
)

plt.title('Consumo Médio por Mês')
plt.xlabel('Mês')
plt.ylabel('Consumo Médio')

plt.xticks(rotation=45)

plt.show()

# Correlação
correlacao = df['CONSUMO-KWH'].corr(df['VALOR BRUTO DA FATURA'])

print("Correlação:", correlacao)

# Gráfico de dispersão
plt.figure(figsize=(8,5))

sns.scatterplot(
    x=df['CONSUMO-KWH'],
    y=df['VALOR BRUTO DA FATURA']
)

plt.title('Correlação entre Consumo e Valor da Fatura')

plt.xlabel('Consumo (KWH)')
plt.ylabel('Valor da Fatura')

plt.show()


import plotly.express as px

#gráfico interativo
fig = px.line(
